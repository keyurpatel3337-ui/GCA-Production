%% Student Use Case Diagram
%% Standard UML format with system boundary

graph TB
    %% External Actor
    Student(("👤<br/>Student"))
    
    %% System Boundary
    subgraph System["&lt;&lt;System&gt;&gt;<br/>Student Portal"]
        direction TB
        
        %% Main Use Cases
        UC1([Register for<br/>Admission])
        UC2([View Profile])
        UC3([Book<br/>Appointments])
        UC4([View My Fees])
        UC5([Make Payment])
        UC6([Request<br/>Installments])
        UC7([View Payment<br/>Receipts])
        UC8([View Test<br/>Results])
        UC9([View Admission<br/>Letter])
        UC10([Submit<br/>Documents])
        UC11([View Installment<br/>Requests])
        UC12([Track Application<br/>Status])

        %% Extended Use Cases
        UC1A([Fill Personal<br/>Details])
        UC1B([Upload<br/>Documents])
        UC1C([Select Course<br/>& Medium])
        UC1D([Choose School<br/>Preference])

        UC3A([Select<br/>Counsellor])
        UC3B([Choose Time<br/>Slot])
        UC3C([Cancel<br/>Appointment])
        
        UC4A([View Total<br/>Fees])
        UC4B([View Paid<br/>Amount])
        UC4C([View Pending<br/>Amount])
        UC4D([View Scholarship<br/>Details])
        
        UC5A([Online<br/>Payment])
        UC5B([Offline<br/>Payment])
        UC5C([Pay Token<br/>Fee])
        UC5D([Pay School<br/>Fee])
        UC5E([Pay Trust<br/>Facilities Fee])
        UC5F([Pay Tuition<br/>Fee])
        UC5G([Pay Hostel<br/>Fee])
        
        UC6A([Select Fee<br/>Component])
        UC6B([Specify<br/>Installment Plan])
        UC6C([Submit<br/>Reason])
        UC6D([Check<br/>Eligibility])
        
        UC10A([Upload<br/>Photo])
        UC10B([Upload Academic<br/>Documents])
        UC10C([Upload ID<br/>Proof])
        UC10D([Upload Address<br/>Proof])
    end
    
    %% Actor Associations
    Student --- UC1
    Student --- UC2
    Student --- UC3
    Student --- UC4
    Student --- UC5
    Student --- UC6
    Student --- UC7
    Student --- UC8
    Student --- UC9
    Student --- UC10
    Student --- UC11
    Student --- UC12
    
    %% Extends relationships
    UC1 -.->|«extend»| UC1A
    UC1 -.->|«extend»| UC1B
    UC1 -.->|«extend»| UC1C
    UC1 -.->|«extend»| UC1D
    
    UC3 -.->|«extend»| UC3A
    UC3 -.->|«extend»| UC3B
    UC3 -.->|«extend»| UC3C
    
    UC4 -.->|«extend»| UC4A
    UC4 -.->|«extend»| UC4B
    UC4 -.->|«extend»| UC4C
    UC4 -.->|«extend»| UC4D
    
    UC5 -.->|«extend»| UC5A
    UC5 -.->|«extend»| UC5B
    UC5 -.->|«extend»| UC5C
    UC5 -.->|«extend»| UC5D
    UC5 -.->|«extend»| UC5E
    UC5 -.->|«extend»| UC5F
    UC5 -.->|«extend»| UC5G
    
    UC6 -.->|«extend»| UC6A
    UC6 -.->|«extend»| UC6B
    UC6 -.->|«extend»| UC6C
    UC6 -.->|«include»| UC6D
    
    UC10 -.->|«extend»| UC10A
    UC10 -.->|«extend»| UC10B
    UC10 -.->|«extend»| UC10C
    UC10 -.->|«extend»| UC10D

    %% Styling
    classDef actorStyle fill:#E3F2FD,stroke:#1976D2,stroke-width:3px,color:#000
    classDef mainUseCase fill:#C8E6C9,stroke:#388E3C,stroke-width:2px,color:#000
    classDef extendedUseCase fill:#FFF9C4,stroke:#F57C00,stroke-width:1px,color:#000
    classDef systemStyle fill:#E8EAF6,stroke:#3F51B5,stroke-width:3px
    
    class Student actorStyle
    class UC1,UC2,UC3,UC4,UC5,UC6,UC7,UC8,UC9,UC10,UC11,UC12 mainUseCase
    class UC1A,UC1B,UC1C,UC1D,UC3A,UC3B,UC3C,UC4A,UC4B,UC4C,UC4D extendedUseCase
    class UC5A,UC5B,UC5C,UC5D,UC5E,UC5F,UC5G extendedUseCase
    class UC6A,UC6B,UC6C,UC6D,UC10A,UC10B,UC10C,UC10D extendedUseCase
    class System systemStyle
