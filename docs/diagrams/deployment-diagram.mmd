%% Deployment Diagram - Counselling Management System
%% Shows physical deployment architecture

graph TB
    %% Client Layer
    subgraph ClientLayer["Client Layer"]
        direction LR
        Browser1[Web Browser<br/>Chrome/Firefox/Edge]
        Browser2[Mobile Browser]
        Desktop[Desktop Application]
    end
    
    %% Load Balancer (Optional)
    LoadBalancer[Load Balancer<br/>Nginx/Apache]
    
    %% Web Server Layer
    subgraph WebServerLayer["Web Server Layer"]
        direction TB
        
        subgraph WebServer1["Web Server 1"]
            Apache1[Apache HTTP Server<br/>Port 80/443]
            PHP1[PHP 7.4+<br/>PHP-FPM]
            Files1[Static Files<br/>CSS/JS/Images]
        end
        
        subgraph WebServer2["Web Server 2 (Optional)"]
            Apache2[Apache HTTP Server<br/>Port 80/443]
            PHP2[PHP 7.4+<br/>PHP-FPM]
            Files2[Static Files<br/>CSS/JS/Images]
        end
        
        Apache1 --> PHP1
        Apache2 --> PHP2
    end
    
    %% Application Server Layer
    subgraph AppServerLayer["Application Server"]
        direction TB
        
        subgraph AppComponents["Application Components"]
            PHPApp[PHP Application<br/>counselling-backend/]
            Controllers[Controllers]
            Modules[Modules]
            Common[Common Libraries]
        end
        
        subgraph SessionStore["Session Storage"]
            Sessions[PHP Sessions<br/>File-based/Redis]
        end
        
        PHPApp --> Controllers
        PHPApp --> Modules
        PHPApp --> Common
        PHPApp --> Sessions
    end
    
    %% Database Layer
    subgraph DatabaseLayer["Database Layer"]
        direction TB
        
        subgraph PrimaryDB["Primary Database Server"]
            MySQL1[MySQL 8.0<br/>Port 3306]
            DBData1[(counselling_db<br/>InnoDB Engine)]
        end
        
        subgraph ReplicaDB["Replica Database Server (Optional)"]
            MySQL2[MySQL 8.0<br/>Port 3306]
            DBData2[(counselling_db<br/>Read Replica)]
        end
        
        MySQL1 --> DBData1
        MySQL2 --> DBData2
        MySQL1 -.->|Replication| MySQL2
    end
    
    %% File Storage Layer
    subgraph StorageLayer["File Storage"]
        direction LR
        FileServer[File Server<br/>NAS/Local Storage]
        Documents[Documents<br/>uploads/documents/]
        Photos[Photos<br/>uploads/photos/]
        Receipts[Receipts<br/>uploads/receipts/]
        
        FileServer --> Documents
        FileServer --> Photos
        FileServer --> Receipts
    end
    
    %% Backup Server
    subgraph BackupLayer["Backup Server"]
        direction TB
        BackupServer[Backup Server]
        DBBackups[(Database Backups<br/>Daily/Weekly)]
        FileBackups[(File Backups<br/>Weekly)]
        
        BackupServer --> DBBackups
        BackupServer --> FileBackups
    end
    
    %% External Services
    subgraph ExternalServices["External Services - Cloud"]
        direction TB
        PaymentGW[Payment Gateway<br/>Easebuzz API<br/>HTTPS]
        EmailSrv[Email Service<br/>SMTP Server<br/>Port 587]
        SMSGateway[SMS Gateway<br/>REST API<br/>HTTPS]
    end
    
    %% Monitoring & Logging
    subgraph Monitoring["Monitoring & Logging"]
        direction LR
        LogServer[Log Server<br/>logs/]
        ErrorLogs[Error Logs]
        AccessLogs[Access Logs]
        AuditLogs[Audit Logs]
        
        LogServer --> ErrorLogs
        LogServer --> AccessLogs
        LogServer --> AuditLogs
    end
    
    %% Network Connections
    Browser1 -.->|HTTPS| LoadBalancer
    Browser2 -.->|HTTPS| LoadBalancer
    Desktop -.->|HTTPS| LoadBalancer
    
    LoadBalancer -->|HTTP| Apache1
    LoadBalancer -->|HTTP| Apache2
    
    PHP1 -->|TCP| AppComponents
    PHP2 -->|TCP| AppComponents
    
    AppComponents -->|PDO/MySQLi| MySQL1
    AppComponents -.->|Read Queries| MySQL2
    
    AppComponents -->|File I/O| FileServer
    
    AppComponents -.->|HTTPS| PaymentGW
    AppComponents -.->|SMTP| EmailSrv
    AppComponents -.->|HTTPS| SMSGateway
    
    MySQL1 -.->|Backup| BackupServer
    FileServer -.->|Backup| BackupServer
    
    Apache1 -->|Logs| LogServer
    Apache2 -->|Logs| LogServer
    PHPApp -->|Error Logs| LogServer
    
    %% Deployment Specifications
    note1[Web Server Specs:<br/>- OS: Windows/Linux<br/>- RAM: 4GB+<br/>- CPU: 2 Core+<br/>- Storage: 50GB SSD]
    note2[Database Server Specs:<br/>- OS: Linux<br/>- RAM: 8GB+<br/>- CPU: 4 Core+<br/>- Storage: 100GB SSD<br/>- RAID 10 for data]
    note3[Network:<br/>- Internal: 1 Gbps LAN<br/>- External: SSL/TLS<br/>- Firewall: Active]
    
    WebServer1 -.- note1
    PrimaryDB -.- note2
    LoadBalancer -.- note3
    
    %% Styling
    classDef clientStyle fill:#E3F2FD,stroke:#1976D2,stroke-width:2px
    classDef webStyle fill:#C8E6C9,stroke:#388E3C,stroke-width:2px
    classDef appStyle fill:#FFF9C4,stroke:#F57C00,stroke-width:2px
    classDef dbStyle fill:#E1BEE7,stroke:#7B1FA2,stroke-width:2px
    classDef storageStyle fill:#FFE0B2,stroke:#E65100,stroke-width:2px
    classDef externalStyle fill:#FFCCBC,stroke:#D84315,stroke-width:2px
    classDef monitorStyle fill:#CFD8DC,stroke:#455A64,stroke-width:2px
    
    class Browser1,Browser2,Desktop clientStyle
    class LoadBalancer,Apache1,Apache2,PHP1,PHP2,Files1,Files2 webStyle
    class PHPApp,Controllers,Modules,Common,Sessions appStyle
    class MySQL1,MySQL2,DBData1,DBData2 dbStyle
    class FileServer,Documents,Photos,Receipts,BackupServer,DBBackups,FileBackups storageStyle
    class PaymentGW,EmailSrv,SMSGateway externalStyle
    class LogServer,ErrorLogs,AccessLogs,AuditLogs monitorStyle
