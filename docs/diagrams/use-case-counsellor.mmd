%% Counsellor Use Case Diagram
%% Standard UML format with system boundary

graph TB
    %% External Actor
    Counsellor(("👤<br/>Counsellor"))
    
    %% System Boundary
    subgraph System["&lt;&lt;System&gt;&gt;<br/>Counsellor Portal"]
        direction TB
        
        %% Main Use Cases
        UC1([View Assigned<br/>Students])
        UC2([Manage<br/>Appointments])
        UC3([Create<br/>Session])
        UC4([View Session<br/>History])
        UC5([Request Fee<br/>Installment])
        UC6([Confirm<br/>Admission])
        UC7([View Student<br/>Details])
        UC8([Upload<br/>Documents])
        UC9([Track Student<br/>Progress])
        UC10([View My<br/>Dashboard])
        UC11([Generate<br/>Reports])
        UC12([Schedule<br/>Follow-ups])

        %% Extended Use Cases
        UC1A([Filter by<br/>Status])
        UC1B([Search<br/>Students])
        UC1C([Sort by<br/>Name/Date])
        
        UC2A([View Appointment<br/>Requests])
        UC2B([Accept/Reject<br/>Appointments])
        UC2C([Reschedule<br/>Appointments])
        UC2D([View Appointment<br/>Calendar])
        
        UC3A([Select<br/>Student])
        UC3B([Record Session<br/>Notes])
        UC3C([Add Session<br/>Objectives])
        UC3D([Track Session<br/>Outcomes])
        UC3E([Verify Student<br/>Assignment])
        
        UC5A([Select<br/>Student])
        UC5B([Choose Fee<br/>Component])
        UC5C([Specify<br/>Terms])
        UC5D([Add<br/>Justification])
        
        UC6A([Verify<br/>Documents])
        UC6B([Calculate<br/>Fees])
        UC6C([Apply<br/>Scholarship])
        UC6D([Set Payment<br/>Mode])
        UC6E([Generate Admission<br/>Letter])
        UC6F([Check<br/>Eligibility])
        
        UC7A([View Academic<br/>Info])
        UC7B([View Fee<br/>Details])
        UC7C([View Test<br/>Results])
        UC7D([View Contact<br/>Info])
        UC7E([View<br/>Documents])
        
        UC8A([Upload Academic<br/>Records])
        UC8B([Upload<br/>Certificates])
        UC8C([Upload<br/>Photos])
    end
    
    %% Actor Associations
    Counsellor --- UC1
    Counsellor --- UC2
    Counsellor --- UC3
    Counsellor --- UC4
    Counsellor --- UC5
    Counsellor --- UC6
    Counsellor --- UC7
    Counsellor --- UC8
    Counsellor --- UC9
    Counsellor --- UC10
    Counsellor --- UC11
    Counsellor --- UC12
    
    %% Relationships
    UC1 -.->|«extend»| UC1A
    UC1 -.->|«extend»| UC1B
    UC1 -.->|«extend»| UC1C
    
    UC2 -.->|«extend»| UC2A
    UC2 -.->|«extend»| UC2B
    UC2 -.->|«extend»| UC2C
    UC2 -.->|«extend»| UC2D
    
    UC3 -.->|«extend»| UC3A
    UC3 -.->|«extend»| UC3B
    UC3 -.->|«extend»| UC3C
    UC3 -.->|«extend»| UC3D
    UC3 -.->|«include»| UC3E
    
    UC5 -.->|«extend»| UC5A
    UC5 -.->|«extend»| UC5B
    UC5 -.->|«extend»| UC5C
    UC5 -.->|«extend»| UC5D
    
    UC6 -.->|«extend»| UC6A
    UC6 -.->|«extend»| UC6B
    UC6 -.->|«extend»| UC6C
    UC6 -.->|«extend»| UC6D
    UC6 -.->|«extend»| UC6E
    UC6 -.->|«include»| UC6F
    
    UC7 -.->|«extend»| UC7A
    UC7 -.->|«extend»| UC7B
    UC7 -.->|«extend»| UC7C
    UC7 -.->|«extend»| UC7D
    UC7 -.->|«extend»| UC7E
    
    UC8 -.->|«extend»| UC8A
    UC8 -.->|«extend»| UC8B
    UC8 -.->|«extend»| UC8C

    %% Styling
    classDef actorStyle fill:#E8F5E9,stroke:#2E7D32,stroke-width:3px,color:#000
    classDef mainUseCase fill:#BBDEFB,stroke:#1565C0,stroke-width:2px,color:#000
    classDef extendedUseCase fill:#FFF9C4,stroke:#F57C00,stroke-width:1px,color:#000
    classDef systemStyle fill:#E8EAF6,stroke:#3F51B5,stroke-width:3px
    
    class Counsellor actorStyle
    class UC1,UC2,UC3,UC4,UC5,UC6,UC7,UC8,UC9,UC10,UC11,UC12 mainUseCase
    class UC1A,UC1B,UC1C,UC2A,UC2B,UC2C,UC2D extendedUseCase
    class UC3A,UC3B,UC3C,UC3D,UC3E extendedUseCase
    class UC5A,UC5B,UC5C,UC5D extendedUseCase
    class UC6A,UC6B,UC6C,UC6D,UC6E,UC6F extendedUseCase
    class UC7A,UC7B,UC7C,UC7D,UC7E extendedUseCase
    class UC8A,UC8B,UC8C extendedUseCase
    class System systemStyle
