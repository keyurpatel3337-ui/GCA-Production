%% Counselling Session Activity Diagram
%% Shows the flow of creating and conducting a counselling session

flowchart TD
    Start([Counsellor Initiates Session]) --> CheckAuth{Counsellor<br/>Logged In?}
    CheckAuth -->|No| RedirectLogin[Redirect to Login]
    CheckAuth -->|Yes| ViewStudents[View Assigned Students]
    
    RedirectLogin --> LoginPage[Login Page]
    LoginPage --> CheckAuth
    
    ViewStudents --> SelectStudent{Select<br/>Student}
    SelectStudent --> FetchStudentData[(Fetch Student Details)]
    
    FetchStudentData --> VerifyAssignment{Student Assigned<br/>to Counsellor?}
    VerifyAssignment -->|No| AccessDenied[Access Denied]
    VerifyAssignment -->|Yes| CheckPreviousSessions[View Previous Sessions]
    
    AccessDenied --> End([End])
    
    CheckPreviousSessions --> CreateSession[Create New Session]
    CreateSession --> SelectSessionType{Select Session<br/>Type}
    
    SelectSessionType -->|Initial| InitialSession[Initial Counselling]
    SelectSessionType -->|Follow-up| FollowUpSession[Follow-up Session]
    SelectSessionType -->|Career Guidance| CareerGuidance[Career Guidance]
    SelectSessionType -->|Academic| AcademicCounselling[Academic Counselling]
    
    InitialSession --> EnterDetails
    FollowUpSession --> EnterDetails
    CareerGuidance --> EnterDetails
    AcademicCounselling --> EnterDetails[Enter Session Details]
    
    EnterDetails --> SetObjectives[Define Session Objectives]
    SetObjectives --> RecordNotes[Record Session Notes]
    RecordNotes --> DocumentIssues{Issues<br/>Identified?}
    
    DocumentIssues -->|Yes| RecordIssues[Document Issues]
    DocumentIssues -->|No| SetActionItems
    RecordIssues --> SetActionItems[Set Action Items]
    
    SetActionItems --> ScheduleFollowUp{Schedule<br/>Follow-up?}
    ScheduleFollowUp -->|Yes| SetFollowUpDate[Set Follow-up Date]
    ScheduleFollowUp -->|No| AddRecommendations
    SetFollowUpDate --> AddRecommendations[Add Recommendations]
    
    AddRecommendations --> RateSession[Rate Session Outcome]
    RateSession --> AttachFiles{Attach<br/>Documents?}
    
    AttachFiles -->|Yes| UploadDocs[Upload Session Documents]
    AttachFiles -->|No| ReviewSession
    UploadDocs --> ReviewSession{Review<br/>Session?}
    
    ReviewSession -->|Needs Changes| EnterDetails
    ReviewSession -->|Complete| SaveSession[(Save Session Record)]
    
    SaveSession --> UpdateStudentRecord[Update Student Progress]
    UpdateStudentRecord --> NotifyStudent[Send Session Summary to Student]
    NotifyStudent --> NotifyPrincipal{Serious Issues<br/>Found?}
    
    NotifyPrincipal -->|Yes| AlertPrincipal[Alert Principal]
    NotifyPrincipal -->|No| LogActivity
    AlertPrincipal --> LogActivity[Log Activity]
    
    LogActivity --> CheckFollowUp{Follow-up<br/>Scheduled?}
    CheckFollowUp -->|Yes| CreateReminder[Create Follow-up Reminder]
    CheckFollowUp -->|No| DisplaySuccess
    CreateReminder --> DisplaySuccess[Display Success Message]
    
    DisplaySuccess --> End
    
    style Start fill:#C8E6C9
    style End fill:#FFCDD2
    style FetchStudentData fill:#E1BEE7
    style SaveSession fill:#E1BEE7
    style CheckAuth fill:#FFF9C4
    style SelectStudent fill:#FFF9C4
    style VerifyAssignment fill:#FFF9C4
    style SelectSessionType fill:#FFF9C4
    style DocumentIssues fill:#FFF9C4
    style ScheduleFollowUp fill:#FFF9C4
    style AttachFiles fill:#FFF9C4
    style ReviewSession fill:#FFF9C4
    style NotifyPrincipal fill:#FFF9C4
    style CheckFollowUp fill:#FFF9C4
