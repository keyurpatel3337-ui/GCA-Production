    %% Styling
    classDef actorStyle fill:#E3F2FD,stroke:#1976D2,stroke-width:3px,color:#000,font-size:11px
    classDef useCaseStyle fill:#FFF9C4,stroke:#F57C00,stroke-width:2px,color:#000,font-size:10px
    classDef systemStyle fill:#E8EAF6,stroke:#3F51B5,stroke-width:3px,color:#000
    
    class Student,Counsellor,Principal,Accountant,SuperAdmin,WebsiteAdmin actorStyle
    class UC1,UC2,UC3,UC4,UC5,UC6,UC7,UC8,UC9,UC10,UC11,UC12,UC13,UC14,UC15,UC16,UC17,UC18 useCaseStyle
