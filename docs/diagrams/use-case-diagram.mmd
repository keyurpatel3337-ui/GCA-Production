%% Counselling Management System - Complete Use Case Diagram
%% Standard UML Use Case Diagram with System Boundary

graph TB
    %% External Actors
    Student(("👤<br/>Student"))
    Counsellor(("👤<br/>Counsellor"))
    Principal(("👤<br/>Principal"))
    Accountant(("👤<br/>Accountant"))
    SuperAdmin(("👤<br/>Super Admin"))
    WebsiteAdmin(("👤<br/>Website Admin"))
    
    %% System Boundary
    subgraph System["&lt;&lt;System&gt;&gt;<br/>Counselling Management Platform"]
        direction TB

        %% Core Use Cases - Student Domain
        UC1([Register for<br/>Admission])
        UC2([View Profile])
        UC3([Book<br/>Appointments])
        UC4([View My Fees])
        UC5([Make Payment])
        UC6([Request<br/>Installments])
        UC7([View Receipts])
        UC8([View Test<br/>Results])
        UC9([View Admission<br/>Letter])
        UC10([Submit<br/>Documents])

        %% Core Use Cases - Counsellor Domain
        UC11([View Assigned<br/>Students])
        UC12([Manage<br/>Appointments])
        UC13([Create<br/>Session])
        UC14([View Session<br/>History])
        UC15([Request Fee<br/>Installment])
        UC16([Confirm<br/>Admission])
        UC17([View Student<br/>Details])
        UC18([Upload<br/>Documents])

        %% Core Use Cases - Principal Domain
        UC19([View All<br/>Students])
        UC20([Manage<br/>Counsellors])
        UC21([Assign Students<br/>to Counsellors])
        UC22([Auto-assign<br/>Students])
        UC23([View Reports])
        UC24([Manage<br/>Divisions])
        UC25([Approve<br/>Installments])
        UC26([View Dashboard])
        UC27([Manage<br/>Scholarships])
        UC28([Manage<br/>Academic Years])

    %% Accountant Use Cases
    Accountant --> UC31[Process Payments]
        %% Core Use Cases - Accountant Domain
        UC29([Process<br/>Payments])
        UC30([Generate<br/>Receipts])
        UC31([Create<br/>Installments])
        UC32([View Payment<br/>History])
        UC33([Manage Fee<br/>Configuration])
        UC34([Process<br/>Refunds])
        UC35([View Daily<br/>Collections])
        UC36([Approve/Reject<br/>Installments])
    SuperAdmin --> UC40[Manage Users]
    SuperAdmin --> UC41[Manage Roles & Permissions]
        %% Core Use Cases - Admin Domain
        UC37([Manage Users])
        UC38([Manage Roles])
        UC39([System<br/>Configuration])
        UC40([View System<br/>Logs])
        UC41([Manage<br/>Schools])
        UC42([Manage<br/>Courses])
        UC43([Database<br/>Backup])
        UC44([View All<br/>Reports])
    WebsiteAdmin --> UC51[Update Gallery]
    WebsiteAdmin --> UC52[Manage Facilities Info]
    WebsiteAdmin --> UC53[Update Contact Info]
    %% Core Use Cases - Website Admin
        UC45([Manage<br/>Content])
        UC46([Update<br/>Gallery])
        UC47([Manage<br/>Facilities])
        UC48([Update<br/>Contact Info])
        
    end
    
    %% Actor to Use Case Associations
    Student --- UC1
    Student --- UC2
    Student --- UC3
    Student --- UC4
    Student --- UC5
    Student --- UC6
    Student --- UC7
    Student --- UC8
    Student --- UC9
    Student --- UC10
    
    Counsellor --- UC11
    Counsellor --- UC12
    Counsellor --- UC13
    Counsellor --- UC14
    Counsellor --- UC15
    Counsellor --- UC16
    Counsellor --- UC17
    Counsellor --- UC18
    
    Principal --- UC19
