%% Accountant Use Case Diagram
%% Standard UML format with system boundary

graph TB
    %% External Actor
    Accountant(("👤<br/>Accountant"))
    
    %% System Boundary
    subgraph System["<<System>><br/>Accounts Portal"]
        direction TB
        
        %% Main Use Cases
        UC1([Process<br/>Payments])
        UC2([Generate<br/>Receipts])
        UC3([Create<br/>Installments])
        UC4([View Payment<br/>History])
        UC5([Manage Fee<br/>Configuration])
        UC6([Process<br/>Refunds])
        UC7([View Daily<br/>Collections])
        UC8([Adjust Fee<br/>Structure])
        UC9([Approve/Reject<br/>Installments])
        UC10([Reconcile<br/>Payments])
        UC11([Generate Financial<br/>Reports])
        UC12([Manage Fee<br/>Components])
        UC13([Track Overdue<br/>Payments])
        UC14([Send Payment<br/>Reminders])

        %% Extended Use Cases
        UC1A([Record Online<br/>Payment])
        UC1B([Record Offline<br/>Payment])
        UC1C([Record Cash<br/>Payment])
        UC1D([Validate Payment<br/>Details])
        UC1E([Update Student<br/>Account])

        UC2A([Print<br/>Receipt])
        UC2B([Email<br/>Receipt])
        UC2C([Download<br/>PDF])
        
        UC5A([Set School<br/>Fee])
        UC5B([Set Tuition<br/>Fee])
        UC5C([Set Hostel<br/>Fee])
        UC5D([Configure<br/>GST])
        
        UC9A([Review<br/>Request])
        UC9B([Verify<br/>Eligibility])
        UC9C([Approve with<br/>Terms])
        UC9D([Reject with<br/>Reason])
    end
    
    %% Actor Associations
    Accountant --- UC1
    Accountant --- UC2
    Accountant --- UC3
    Accountant --- UC4
    Accountant --- UC5
    Accountant --- UC6
    Accountant --- UC7
    Accountant --- UC8
    Accountant --- UC9
    Accountant --- UC10
    Accountant --- UC11
    Accountant --- UC12
    Accountant --- UC13
    Accountant --- UC14
    
    %% Relationships
    UC1 -.->|«extend»| UC1A
    UC1 -.->|«extend»| UC1B
    UC1 -.->|«extend»| UC1C
    UC1 -.->|«include»| UC1D
    UC1 -.->|«include»| UC1E
    
    UC2 -.->|«extend»| UC2A
    UC2 -.->|«extend»| UC2B
    UC2 -.->|«extend»| UC2C
    
    UC5 -.->|«extend»| UC5A
    UC5 -.->|«extend»| UC5B
    UC5 -.->|«extend»| UC5C
    UC5 -.->|«extend»| UC5D
    
    UC9 -.->|«extend»| UC9A
    UC9 -.->|«extend»| UC9B
    UC9 -.->|«extend»| UC9C
    UC9 -.->|«extend»| UC9D

    %% Styling
    classDef actorStyle fill:#E0F2F1,stroke:#00695C,stroke-width:3px,color:#000
    classDef mainUseCase fill:#C5CAE9,stroke:#303F9F,stroke-width:2px,color:#000
    classDef extendedUseCase fill:#FFF9C4,stroke:#F57C00,stroke-width:1px,color:#000
    classDef systemStyle fill:#E8EAF6,stroke:#3F51B5,stroke-width:3px
    
    class Accountant actorStyle
    class UC1,UC2,UC3,UC4,UC5,UC6,UC7,UC8,UC9,UC10,UC11,UC12,UC13,UC14 mainUseCase
    class UC1A,UC1B,UC1C,UC1D,UC1E extendedUseCase
    class UC2A,UC2B,UC2C extendedUseCase
    class UC5A,UC5B,UC5C,UC5D extendedUseCase
    class UC9A,UC9B,UC9C,UC9D extendedUseCase
    class System systemStyle
