%% Principal Use Case Diagram
%% Standard UML format with system boundary

graph TB
    %% External Actor
    Principal(("👤<br/>Principal"))
    
    %% System Boundary
    subgraph System["<<System>><br/>Principal Portal"]
        direction TB
        
        %% Main Use Cases
        UC1([View All<br/>Students])
        UC2([Manage<br/>Counsellors])
        UC3([Assign Students<br/>to Counsellors])
        UC4([Auto-assign<br/>Students])
        UC5([View<br/>Reports])
        UC6([Manage<br/>Divisions])
        UC7([Approve<br/>Installments])
        UC8([View<br/>Dashboard])
        UC9([Confirm<br/>Admission])
        UC10([Manage<br/>Scholarships])
        UC11([View Fee<br/>Collections])
        UC12([Manage Academic<br/>Years])
        UC13([View System<br/>Analytics])
        UC14([Monitor Counsellor<br/>Performance])
        UC15([Oversee Student<br/>Progress])

        %% Extended Use Cases
        UC1A([Filter by<br/>Course])
        UC1B([Filter by<br/>Counsellor])
        UC1C([Filter by<br/>Status])
        UC1D([Search<br/>Students])
        UC1E([Export Student<br/>List])

        UC2A([Add<br/>Counsellor])
        UC2B([Edit<br/>Counsellor])
        UC2C([Deactivate<br/>Counsellor])
        UC2D([View Counsellor<br/>Details])
        
        UC3A([Manual<br/>Assignment])
        UC3B([Reassign<br/>Students])
        UC3C([Unassign<br/>Students])
        UC3D([Check Counsellor<br/>Capacity])
        
        UC4A([Set Distribution<br/>Rules])
        UC4B([Balance<br/>Load])
        UC4C([Validate<br/>Assignments])
        
        UC5A([Daily Registration<br/>Report])
        UC5B([Weekly Summary<br/>Report])
        UC5C([Monthly<br/>Report])
        UC5D([Quarterly<br/>Report])
        UC5E([Custom<br/>Reports])
        UC5F([Export<br/>Reports])
        
        UC7A([Review Request<br/>Details])
        UC7B([Approve<br/>Request])
        UC7C([Reject<br/>Request])
        UC7D([Request More<br/>Info])
        
        UC10A([Define Scholarship<br/>Rules])
        UC10B([Approve<br/>Applications])
        UC10C([Modify<br/>Amount])
    end
    
    %% Actor Associations
    Principal --- UC1
    Principal --- UC2
    Principal --- UC3
    Principal --- UC4
    Principal --- UC5
    Principal --- UC6
    Principal --- UC7
    Principal --- UC8
    Principal --- UC9
    Principal --- UC10
    Principal --- UC11
    Principal --- UC12
    Principal --- UC13
    Principal --- UC14
    Principal --- UC15
    
    %% Relationships
    UC1 -.->|«extend»| UC1A
    UC1 -.->|«extend»| UC1B
    UC1 -.->|«extend»| UC1C
    UC1 -.->|«extend»| UC1D
    UC1 -.->|«extend»| UC1E
    
    UC2 -.->|«extend»| UC2A
    UC2 -.->|«extend»| UC2B
    UC2 -.->|«extend»| UC2C
    UC2 -.->|«extend»| UC2D
    
    UC3 -.->|«extend»| UC3A
    UC3 -.->|«extend»| UC3B
    UC3 -.->|«extend»| UC3C
    UC3 -.->|«include»| UC3D
    
    UC4 -.->|«extend»| UC4A
    UC4 -.->|«extend»| UC4B
    UC4 -.->|«include»| UC4C
    
    UC5 -.->|«extend»| UC5A
    UC5 -.->|«extend»| UC5B
    UC5 -.->|«extend»| UC5C
    UC5 -.->|«extend»| UC5D
    UC5 -.->|«extend»| UC5E
    UC5 -.->|«extend»| UC5F
    
    UC7 -.->|«extend»| UC7A
    UC7 -.->|«extend»| UC7B
    UC7 -.->|«extend»| UC7C
    UC7 -.->|«extend»| UC7D
    
    UC10 -.->|«extend»| UC10A
    UC10 -.->|«extend»| UC10B
    UC10 -.->|«extend»| UC10C

    %% Styling
    classDef actorStyle fill:#F3E5F5,stroke:#7B1FA2,stroke-width:3px,color:#000
    classDef mainUseCase fill:#FFE0B2,stroke:#E65100,stroke-width:2px,color:#000
    classDef extendedUseCase fill:#FFF9C4,stroke:#F57C00,stroke-width:1px,color:#000
    classDef systemStyle fill:#E8EAF6,stroke:#3F51B5,stroke-width:3px
    
    class Principal actorStyle
    class UC1,UC2,UC3,UC4,UC5,UC6,UC7,UC8,UC9,UC10,UC11,UC12,UC13,UC14,UC15 mainUseCase
    class UC1A,UC1B,UC1C,UC1D,UC1E,UC2A,UC2B,UC2C,UC2D extendedUseCase
    class UC3A,UC3B,UC3C,UC3D,UC4A,UC4B,UC4C extendedUseCase
    class UC5A,UC5B,UC5C,UC5D,UC5E,UC5F extendedUseCase
    class UC7A,UC7B,UC7C,UC7D,UC10A,UC10B,UC10C extendedUseCase
    class System systemStyle
