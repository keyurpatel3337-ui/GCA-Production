%% Student Assignment to Counsellor Activity Diagram
%% Shows the flow of assigning students to counsellors

flowchart TD
    Start([Principal Initiates Assignment]) --> CheckAuth{User<br/>Authorized?}
    CheckAuth -->|No| AccessDenied[Access Denied]
    CheckAuth -->|Yes| SelectMethod{Select Assignment<br/>Method}
    
    AccessDenied --> End([End])
    
    SelectMethod -->|Manual| ManualAssignment[Manual Assignment]
    SelectMethod -->|Auto| AutoAssignment[Auto Assignment]
    
    ManualAssignment --> FetchUnassigned[(Fetch Unassigned Students)]
    FetchUnassigned --> DisplayStudents[Display Student List]
    DisplayStudents --> SelectStudents[Select Students]
    
    SelectStudents --> FetchCounsellors[(Fetch Active Counsellors)]
    FetchCounsellors --> DisplayCounsellors[Display Counsellor List]
    DisplayCounsellors --> ShowWorkload[Show Current Workload]
    
    ShowWorkload --> SelectCounsellor{Select<br/>Counsellor}
    SelectCounsellor --> CheckCapacity{Check Counsellor<br/>Capacity}
    
    CheckCapacity -->|Over Capacity| WarningOverload[Show Overload Warning]
    CheckCapacity -->|Within Capacity| ConfirmAssignment
    WarningOverload --> ProceedAnyway{Proceed<br/>Anyway?}
    
    ProceedAnyway -->|No| SelectCounsellor
    ProceedAnyway -->|Yes| ConfirmAssignment{Confirm<br/>Assignment?}
    
    ConfirmAssignment -->|No| SelectCounsellor
    ConfirmAssignment -->|Yes| SaveManualAssignment[(Save Assignment)]
    
    AutoAssignment --> SetParameters[Set Auto-Assignment Parameters]
    SetParameters --> InputPerCounsellor[Input Students per Counsellor]
    InputPerCounsellor --> FetchAllUnassigned[(Fetch All Unassigned Students)]
    FetchAllUnassigned --> FetchAllCounsellors[(Fetch All Active Counsellors)]
    
    FetchAllCounsellors --> CalculateDistribution[Calculate Distribution]
    CalculateDistribution --> CheckCounsellors{Counsellors<br/>Available?}
    
    CheckCounsellors -->|No| NoGCounsellorsError[No Counsellors Available Error]
    NoGCounsellorsError --> End
    
    CheckCounsellors -->|Yes| BalanceLoad[Balance Load Evenly]
    BalanceLoad --> ConsiderFactors{Consider<br/>Factors?}
    
    ConsiderFactors -->|Course| GroupByCourse[Group by Course]
    ConsiderFactors -->|Medium| GroupByMedium[Group by Medium]
    ConsiderFactors -->|Random| RandomDistribution[Random Distribution]
    ConsiderFactors -->|Round Robin| RoundRobin[Round Robin Distribution]
    
    GroupByCourse --> CreateAssignments
    GroupByMedium --> CreateAssignments
    RandomDistribution --> CreateAssignments
    RoundRobin --> CreateAssignments[Create Assignment List]
    
    CreateAssignments --> PreviewAssignments[Preview Assignment Summary]
    PreviewAssignments --> ReviewAuto{Review &<br/>Confirm?}
    
    ReviewAuto -->|No| ModifyParams[Modify Parameters]
    ModifyParams --> SetParameters
    ReviewAuto -->|Yes| SaveAutoAssignments[(Save All Assignments)]
    
    SaveManualAssignment --> UpdateRecords
    SaveAutoAssignments --> UpdateRecords[Update Student Records]
    
    UpdateRecords --> UpdateCounsellorLoad[Update Counsellor Workload]
    UpdateCounsellorLoad --> NotifyAllCounsellors[Notify Assigned Counsellors]
    NotifyAllCounsellors --> NotifyStudents[Notify Assigned Students]
    
    NotifyStudents --> GenerateReport[Generate Assignment Report]
    GenerateReport --> LogActivity[Log Assignment Activity]
    LogActivity --> DisplaySuccess[Display Success Message]
    
    DisplaySuccess --> ShowSummary{Show<br/>Summary?}
    ShowSummary -->|Yes| DisplayStats[Display Assignment Statistics]
    ShowSummary -->|No| End
    DisplayStats --> End
    
    style Start fill:#C8E6C9
    style End fill:#FFCDD2
    style FetchUnassigned fill:#E1BEE7
    style FetchCounsellors fill:#E1BEE7
    style FetchAllUnassigned fill:#E1BEE7
    style FetchAllCounsellors fill:#E1BEE7
    style SaveManualAssignment fill:#E1BEE7
    style SaveAutoAssignments fill:#E1BEE7
    style CheckAuth fill:#FFF9C4
    style SelectMethod fill:#FFF9C4
    style SelectCounsellor fill:#FFF9C4
    style CheckCapacity fill:#FFF9C4
    style ProceedAnyway fill:#FFF9C4
    style ConfirmAssignment fill:#FFF9C4
    style CheckCounsellors fill:#FFF9C4
    style ConsiderFactors fill:#FFF9C4
    style ReviewAuto fill:#FFF9C4
    style ShowSummary fill:#FFF9C4
