%% Entity Relationship Diagram - Counselling Management System
%% Shows database entities, attributes, and relationships

erDiagram
    %% Core User Management
    USER ||--|| ROLE : "has"
    USER {
        int id PK
        string name
        string email UK
        string password
        string phone UK
        int role_id FK
        string status
        datetime created_at
        datetime updated_at
        int created_by FK
    }
    
    ROLE {
        int id PK
        string role_name
        string role_code UK
        string description
        datetime created_at
    }
    
    %% Student Entity
    STUDENT ||--|| COURSE : "enrolled_in"
    STUDENT ||--|| SCHOOL : "studies_at"
    STUDENT ||--|| BOARD : "follows"
    STUDENT ||--|| MEDIUM : "studies_in"
    STUDENT ||--o| GROUP : "belongs_to"
    STUDENT ||--o| USER : "assigned_to_counsellor"
    STUDENT ||--o| ENROLLED_STUDENT : "has_enrollment"
    
    STUDENT {
        int id PK
        string student_name
        string surname
        string email UK
        string mob UK
        date dob
        string gender
        string father_name
        string mother_name
        text address
        string city
        string state
        string pincode
        int course_id FK
        int school_id FK
        int board_id FK
        int standard
        int medium_id FK
        int group_id FK
        int counsellor_id FK
        int enrollment_id FK
        boolean is_enrolled
        boolean token_fees_paid
        datetime enrollment_date
        string status
        datetime created_at
        datetime updated_at
        int created_by FK
    }
    
    %% Academic Master Tables
    COURSE {
        int id PK
        string course_name
        string course_code UK
        string description
        boolean is_active
        datetime created_at
        int created_by FK
    }
    
    SCHOOL {
        int id PK
        string school_name
        string school_code UK
        string address
        string contact
        boolean is_active
        datetime created_at
        int created_by FK
    }
    
    BOARD {
        int id PK
        string board_name
        string board_code UK
        string description
        boolean is_active
        datetime created_at
    }
    
    MEDIUM {
        int id PK
        string medium_name
        string medium_code UK
        boolean is_active
        datetime created_at
    }
    
    GROUP {
        int id PK
        string group_name
        string group_code UK
        string description
        boolean is_active
        datetime created_at
    }
    
    %% Enrollment
    ENROLLED_STUDENT ||--|| STUDENT : "refers_to"
    ENROLLED_STUDENT ||--|| COURSE : "for_course"
    ENROLLED_STUDENT ||--|| SCHOOL : "at_school"
    ENROLLED_STUDENT ||--|| BOARD : "under_board"
    ENROLLED_STUDENT ||--|| MEDIUM : "in_medium"
    ENROLLED_STUDENT ||--o| GROUP : "in_group"
    ENROLLED_STUDENT ||--o| USER : "assigned_counsellor"
    
    ENROLLED_STUDENT {
        int id PK
        int student_id FK
        string enrollment_no UK
        int course_id FK
        int school_id FK
        int board_id FK
        int standard
        int medium_id FK
        int group_id FK
        string academic_year
        boolean is_scholarship_student
        decimal scholarship_amount
        int counsellor_id FK
        datetime enrollment_date
        string status
        datetime created_at
        int created_by FK
    }
    
    %% Fee Configuration
    FEE_CONFIGURATION ||--|| COURSE : "for_course"
    FEE_CONFIGURATION ||--|| SCHOOL : "at_school"
    FEE_CONFIGURATION ||--|| MEDIUM : "in_medium"
    FEE_CONFIGURATION ||--o| GROUP : "for_group"
    
    FEE_CONFIGURATION {
        int id PK
        int course_id FK
        int school_id FK
        int medium_id FK
        int group_id FK
        decimal total_fees
        decimal school_fee
        decimal trust_facilities_fee
        decimal tuition_fee_part1
        decimal tuition_fee_part2
        decimal hostel_fee
        int number_of_installments
        string academic_year
        boolean is_active
        datetime created_at
        int created_by FK
    }
    
    %% Student Fee Allocation
    STUDENT ||--o{ STUDENT_FEE_ALLOCATION : "has"
    FEE_CONFIGURATION ||--o{ STUDENT_FEE_ALLOCATION : "defines"
    
    STUDENT_FEE_ALLOCATION {
        int id PK
        int student_id FK
        int fee_config_id FK
        decimal allocated_amount
        decimal paid_amount
        decimal pending_amount
        string status
        string academic_year
        datetime allocated_at
        int created_by FK
    }
    
    %% Payment
    STUDENT ||--o{ PAYMENT : "makes"
    USER ||--o{ PAYMENT : "processes"
    
    PAYMENT {
        int id PK
        int student_id FK
        string receipt_no UK
        decimal amount
        string payment_type
        string fee_component
        string payment_mode
        string transaction_id
        string transaction_ref
        string status
        text remarks
        datetime payment_date
        int created_by FK
        datetime created_at
    }
    
    %% Installment Request
    STUDENT ||--o{ INSTALLMENT_REQUEST : "creates"
    USER ||--o{ INSTALLMENT_REQUEST : "approves_accountant"
    USER ||--o{ INSTALLMENT_REQUEST : "approves_principal"
    
    INSTALLMENT_REQUEST {
        int id PK
        int student_id FK
        string fee_component
        decimal total_amount
        int number_of_installments
        text reason
        string status
        text accountant_remarks
        text principal_remarks
        int requested_by FK
        int approved_by_accountant FK
        int approved_by_principal FK
        datetime requested_at
        datetime accountant_approved_at
        datetime principal_approved_at
    }
    
    %% Installment
    INSTALLMENT_REQUEST ||--o{ INSTALLMENT : "generates"
    STUDENT ||--o{ INSTALLMENT : "has"
    INSTALLMENT ||--o| PAYMENT : "paid_via"
    
    INSTALLMENT {
        int id PK
        int request_id FK
        int student_id FK
        int installment_number
        decimal amount
        date due_date
        string payment_status
        int payment_id FK
        datetime paid_at
        datetime created_at
        int created_by FK
    }
    
    %% Counselling Session
    STUDENT ||--o{ COUNSELLING_SESSION : "participates_in"
    USER ||--o{ COUNSELLING_SESSION : "conducted_by"
    
    COUNSELLING_SESSION {
        int id PK
        int student_id FK
        int counsellor_id FK
        string session_type
        datetime session_date
        int duration_minutes
        text session_notes
        text issues_discussed
        text objectives
        text outcomes
        text recommendations
        date next_followup_date
        string status
        datetime created_at
        int created_by FK
    }
    
    %% Appointment
    STUDENT ||--o{ APPOINTMENT : "books"
    USER ||--o{ APPOINTMENT : "has"
    
    APPOINTMENT {
        int id PK
        int student_id FK
        int counsellor_id FK
        datetime appointment_date
        string appointment_time
        string purpose
        string status
        text notes
        datetime created_at
        datetime updated_at
    }
    
    %% Scholarship
    SCHOLARSHIP_TYPE ||--o{ SCHOLARSHIP_RULE : "defines"
    SCHOLARSHIP_RULE ||--|| COURSE : "applies_to"
    
    SCHOLARSHIP_TYPE {
        int id PK
        string type_name
        string type_code UK
        string description
        boolean is_active
        datetime created_at
    }
    
    SCHOLARSHIP_RULE {
        int id PK
        int scholarship_type_id FK
        int course_id FK
        decimal percentage
        decimal fixed_amount
        decimal min_percentage
        decimal max_percentage
        string criteria
        boolean is_active
        datetime created_at
        int created_by FK
    }
    
    %% Test Management
    TEST ||--|| COURSE : "for_course"
    TEST ||--|| ANSWER_KEY : "has"
    STUDENT ||--o{ TEST_RESULT : "has"
    TEST ||--o{ TEST_RESULT : "produces"
    
    TEST {
        int id PK
        string test_name
        string test_code UK
        int course_id FK
        date test_date
        int total_marks
        int duration_minutes
        text instructions
        boolean is_active
        datetime created_at
        int created_by FK
    }
    
    ANSWER_KEY {
        int id PK
        int test_id FK
        text answers
        text marking_scheme
        datetime created_at
        int created_by FK
    }
    
    TEST_RESULT {
        int id PK
        int student_id FK
        int test_id FK
        decimal marks_obtained
        decimal percentage
        string grade
        int rank
        text remarks
        datetime result_date
        datetime created_at
        int created_by FK
    }
    
    %% Document Management
    STUDENT ||--o{ DOCUMENT : "uploads"
    USER ||--o{ DOCUMENT : "uploaded_by"
    
    DOCUMENT {
        int id PK
        int student_id FK
        string document_type
        string document_name
        string file_name
        string file_path
        string file_size
        string mime_type
        boolean is_verified
        int uploaded_by FK
        int verified_by FK
        datetime uploaded_at
        datetime verified_at
    }
