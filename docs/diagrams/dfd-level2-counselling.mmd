%% Data Flow Diagram - Level 2
%% Process 6.0: Counselling Management (Detailed)

graph TB
    %% External Entities
    Student([Student])
    Counsellor([Counsellor])
    Principal([Principal])
    
    %% Sub-Processes
    P61[("6.1<br/>Book<br/>Appointment")]
    P62[("6.2<br/>Manage<br/>Appointment<br/>Schedule")]
    P63[("6.3<br/>Conduct<br/>Counselling<br/>Session")]
    P64[("6.4<br/>Record<br/>Session<br/>Notes")]
    P65[("6.5<br/>Schedule<br/>Follow-up")]
    P66[("6.6<br/>Assign<br/>Student to<br/>Counsellor")]
    P67[("6.7<br/>Track<br/>Session<br/>Progress")]
    P68[("6.8<br/>Generate<br/>Session<br/>Reports")]
    
    %% Data Stores
    D1[(D1: Students)]
    D2[(D2: Counsellors)]
    D3[(D3: Appointments)]
    D4[(D4: Sessions)]
    D5[(D5: Assignments)]
    D6[(D6: Session Types)]
    
    %% Process 6.1 - Book Appointment
    Student -->|Appointment Request<br/>Preferred Date/Time<br/>Purpose| P61
    P61 <-->|Counsellor Info| D2
    P61 <-->|Existing Appointments| D3
    P61 -->|Check Availability<br/>Time Slots| P61
    P61 -->|No Slots Available| Student
    P61 -->|Appointment Created| D3
    P61 -->|Confirmation<br/>Date, Time<br/>Counsellor Name| Student
    P61 -->|New Appointment Alert| Counsellor
    
    %% Process 6.2 - Manage Schedule
    Counsellor <-->|View Appointments| D3
    Counsellor -->|Action:<br/>Confirm/Reschedule/Cancel| P62
    P62 <-->|Update Appointment| D3
    P62 -->|Status Change<br/>Rescheduled Date/Time| Student
    P62 -->|Today's Schedule| Counsellor
    
    %% Process 6.3 - Conduct Session
    Counsellor -->|Start Session<br/>Student ID| P63
    P63 <-->|Student Profile| D1
    P63 <-->|Appointment Details| D3
    P63 <-->|Previous Sessions| D4
    P63 -->|Session Types:<br/>- Initial Counselling<br/>- Follow-up<br/>- Career Guidance<br/>- Academic Support| Counsellor
    P63 <-->|Session Type Info| D6
    P63 -->|Session Started| P64
    
    %% Process 6.4 - Record Notes
    Counsellor -->|Session Details:<br/>- Date & Duration<br/>- Session Type<br/>- Issues Discussed<br/>- Observations<br/>- Recommendations<br/>- Action Items| P64
    P64 <-->|Student Info| D1
    P64 -->|Session Record| D4
    P64 -->|Notes Saved| Counsellor
    P64 -->|Session Complete| P65
    P64 <-->|Update Appointment<br/>Status: Completed| D3
    
    %% Process 6.5 - Schedule Follow-up
    P65 <-->|Session Details| D4
    P65 -->|Follow-up Required?| P65
    P65 -->|No Follow-up| P67
    P65 -->|Follow-up Date<br/>Purpose| Counsellor
    Counsellor -->|Follow-up Details| P65
    P65 -->|Create Follow-up<br/>Appointment| D3
    P65 -->|Follow-up Reminder| Student
    P65 -->|Follow-up Scheduled| P67
    
    %% Process 6.6 - Student Assignment
    Principal -->|Assignment Request<br/>Student ID<br/>Counsellor ID<br/>OR Auto-assign| P66
    P66 <-->|Student Details| D1
    P66 <-->|Counsellor List<br/>Current Load<br/>Specialization| D2
    P66 -->|Assignment Logic:<br/>- Manual Assignment<br/>- Auto: Load Balance<br/>- By Course/Medium<br/>- Round Robin| P66
    P66 -->|Assignment Record| D5
    P66 <-->|Update Counsellor ID| D1
    P66 -->|Assignment Notice| Student
    P66 -->|New Student Alert| Counsellor
    P66 -->|Assignment Complete| Principal
    
    %% Process 6.7 - Track Progress
    P67 <-->|All Sessions| D4
    P67 <-->|Student Info| D1
    P67 <-->|Counsellor Info| D2
    P67 -->|Track:<br/>- Session Count<br/>- Last Session Date<br/>- Follow-up Status<br/>- Issues Resolved<br/>- Action Items Pending| P67
    P67 -->|Progress Summary| Counsellor
    P67 -->|Send to Reporting| P68
    
    %% Process 6.8 - Generate Reports
    Counsellor -->|Report Request<br/>Date Range, Student| P68
    Principal -->|Report Request<br/>All Counsellors| P68
    P68 <-->|Session Data| D4
    P68 <-->|Student Data| D1
    P68 <-->|Counsellor Data| D2
    P68 <-->|Assignment Data| D5
    P68 -->|Reports:<br/>- Individual Student Progress<br/>- Counsellor Session Summary<br/>- Session Type Distribution<br/>- Follow-up Pending List<br/>- Monthly Statistics| Counsellor
    P68 -->|Management Reports<br/>Overall Statistics| Principal
    
    %% Styling
    classDef entityStyle fill:#E3F2FD,stroke:#1976D2,stroke-width:3px
    classDef processStyle fill:#C8E6C9,stroke:#388E3C,stroke-width:3px
    classDef datastoreStyle fill:#FFE0B2,stroke:#E65100,stroke-width:3px
    
    class Student,Counsellor,Principal entityStyle
    class P61,P62,P63,P64,P65,P66,P67,P68 processStyle
    class D1,D2,D3,D4,D5,D6 datastoreStyle
