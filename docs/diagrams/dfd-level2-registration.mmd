%% Data Flow Diagram - Level 2
%% Process 2.0: Student Registration (Detailed)

graph TB
    %% External Entities
    Student([Student])
    Counsellor([Counsellor])
    
    %% Sub-Processes
    P21[("2.1<br/>Validate<br/>Registration<br/>Form")]
    P22[("2.2<br/>Check<br/>Duplicate<br/>Student")]
    P23[("2.3<br/>Upload<br/>Documents")]
    P24[("2.4<br/>Assign<br/>Counsellor")]
    P25[("2.5<br/>Generate<br/>Student ID")]
    P26[("2.6<br/>Send<br/>Welcome<br/>Notification")]
    
    %% Data Stores
    D1[(D1: Users)]
    D2[(D2: Students)]
    D3[(D3: Documents)]
    D4[(D4: Courses)]
    D5[(D5: Schools)]
    D6[(D6: Counsellors)]
    
    %% Student to Process 2.1
    Student -->|Registration Form<br/>Name, Email, Phone, DOB<br/>Course, School, Medium| P21
    
    %% Process 2.1 - Validation
    P21 -->|Invalid Data| Student
    P21 -->|Valid Data| P22
    P21 <-->|Course Info| D4
    P21 <-->|School Info| D5
    
    %% Process 2.2 - Duplicate Check
    P22 <-->|Check Email/Phone| D2
    P22 <-->|Check User Exists| D1
    P22 -->|Duplicate Found| Student
    P22 -->|Unique Student| P23
    
    %% Process 2.3 - Document Upload
    Student -->|Photo, ID Proof<br/>Address Proof, Certificates| P23
    P23 -->|Document Data| D3
    P23 -->|Upload Failed| Student
    P23 -->|Upload Success| P24
    
    %% Process 2.4 - Counsellor Assignment
    P24 <-->|Counsellor List<br/>Current Load| D6
    P24 <-->|Course/Medium| D2
    P24 -->|Assignment Logic<br/>- By Course<br/>- By Medium<br/>- Load Balance<br/>- Round Robin| P25
    
    %% Process 2.5 - Generate Student ID
    P25 -->|Student Record| D2
    P25 -->|Student Credentials| D1
    P25 -->|Registration Complete| P26
    
    %% Process 2.6 - Send Notification
    P26 -->|Welcome Email<br/>Login Credentials<br/>Next Steps| Student
    P26 -->|New Student Alert<br/>Student Details| Counsellor
    P26 <-->|Student Info| D2
    
    %% Data Flows between stores
    D2 -.->|Student-Counsellor Link| D6
    D1 -.->|User-Student Link| D2
    
    %% Return flows
    P25 -->|Student ID<br/>Registration Success| Student
    
    %% Styling
    classDef entityStyle fill:#E3F2FD,stroke:#1976D2,stroke-width:3px
    classDef processStyle fill:#C8E6C9,stroke:#388E3C,stroke-width:3px
    classDef datastoreStyle fill:#FFE0B2,stroke:#E65100,stroke-width:3px
    
    class Student,Counsellor entityStyle
    class P21,P22,P23,P24,P25,P26 processStyle
    class D1,D2,D3,D4,D5,D6 datastoreStyle
