%% Class Diagram - Counselling Management System
%% Shows main entities, their attributes, methods, and relationships

classDiagram
    %% Core User Classes
    class User {
        +int id
        +string name
        +string email
        +string password
        +string phone
        +int role_id
        +string status
        +datetime created_at
        +datetime updated_at
        +login()
        +logout()
        +resetPassword()
        +updateProfile()
    }
    
    class Role {
        +int id
        +string role_name
        +string role_code
        +datetime created_at
        +getPermissions()
        +assignToUser()
    }
    
    class Student {
        +int id
        +string student_name
        +string surname
        +string email
        +string mob
        +date dob
        +string gender
        +int course_id
        +int school_id
        +int board_id
        +int medium_id
        +int group_id
        +int counsellor_id
        +int enrollment_id
        +boolean is_enrolled
        +boolean token_fees_paid
        +datetime enrollment_date
        +register()
        +uploadDocument()
        +viewFees()
        +makePayment()
        +bookAppointment()
    }
    
    class Counsellor {
        +int user_id
        +string specialization
        +int max_students
        +int current_load
        +viewAssignedStudents()
        +createSession()
        +requestInstallment()
        +confirmAdmission()
    }
    
    class Principal {
        +int user_id
        +assignCounsellors()
        +approveRequests()
        +viewReports()
        +manageScholarships()
    }
    
    class Accountant {
        +int user_id
        +processPayment()
        +generateReceipt()
        +createInstallment()
        +approveInstallmentRequest()
        +viewCollections()
    }
    
    %% Academic Classes
    class Course {
        +int id
        +string course_name
        +string course_code
        +string description
        +boolean is_active
        +datetime created_at
        +getStudents()
        +getFeeStructure()
    }
    
    class School {
        +int id
        +string school_name
        +string school_code
        +string address
        +string contact
        +boolean is_active
        +getEnrolledStudents()
    }
    
    class Board {
        +int id
        +string board_name
        +string board_code
        +getStandards()
    }
    
    class Medium {
        +int id
        +string medium_name
        +string medium_code
    }
    
    class Group {
        +int id
        +string group_name
        +string group_code
        +string description
    }
    
    %% Enrollment & Fee Classes
    class EnrolledStudent {
        +int id
        +int student_id
        +string enrollment_no
        +int course_id
        +int school_id
        +int board_id
        +int standard
        +int medium_id
        +int group_id
        +string academic_year
        +boolean is_scholarship_student
        +decimal scholarship_amount
        +int counsellor_id
        +datetime enrollment_date
        +getEnrollmentDetails()
        +updateStatus()
    }
    
    class FeeConfiguration {
        +int id
        +int course_id
        +int school_id
        +int medium_id
        +int group_id
        +decimal total_fees
        +decimal school_fee
        +decimal trust_facilities_fee
        +decimal tuition_fee_part1
        +decimal tuition_fee_part2
        +decimal hostel_fee
        +int number_of_installments
        +boolean is_active
        +calculateTotalFees()
        +applyScholarship()
    }
    
    class StudentFeeAllocation {
        +int id
        +int student_id
        +int fee_config_id
        +decimal allocated_amount
        +decimal paid_amount
        +decimal pending_amount
        +string status
        +string academic_year
        +datetime allocated_at
        +updatePayment()
        +getPendingAmount()
    }
    
    class Payment {
        +int id
        +int student_id
        +string receipt_no
        +decimal amount
        +string payment_type
        +string fee_component
        +string payment_mode
        +string transaction_id
        +string status
        +datetime payment_date
        +int created_by
        +processPayment()
        +generateReceipt()
        +refund()
    }
    
    class InstallmentRequest {
        +int id
        +int student_id
        +string fee_component
        +decimal total_amount
        +int number_of_installments
        +string reason
        +string status
        +int requested_by
        +int approved_by_accountant
        +int approved_by_principal
        +datetime requested_at
        +submitRequest()
        +approve()
        +reject()
    }
    
    class Installment {
        +int id
        +int request_id
        +int student_id
        +int installment_number
        +decimal amount
        +date due_date
        +string payment_status
        +int payment_id
        +datetime paid_at
        +recordPayment()
        +sendReminder()
    }
    
    %% Counselling Session Classes
    class CounsellingSession {
        +int id
        +int student_id
        +int counsellor_id
        +string session_type
        +datetime session_date
        +text session_notes
        +text objectives
        +text outcomes
        +text recommendations
        +date next_followup_date
        +string status
        +createSession()
        +updateNotes()
        +scheduleFollowUp()
    }
    
    class Appointment {
        +int id
        +int student_id
        +int counsellor_id
        +datetime appointment_date
        +string status
        +text notes
        +datetime created_at
        +book()
        +cancel()
        +reschedule()
        +confirm()
    }
    
    %% Scholarship Classes
    class ScholarshipType {
        +int id
        +string type_name
        +string type_code
        +string description
        +getScholarshipRules()
    }
    
    class ScholarshipRule {
        +int id
        +int scholarship_type_id
        +int course_id
        +decimal percentage
        +decimal fixed_amount
        +decimal min_percentage
        +decimal max_percentage
        +boolean is_active
        +calculateScholarship()
        +validate()
    }
    
    %% Test Management Classes
    class Test {
        +int id
        +string test_name
        +int course_id
        +date test_date
        +int total_marks
        +int duration_minutes
        +boolean is_active
        +createTest()
        +getResults()
    }
    
    class AnswerKey {
        +int id
        +int test_id
        +text answers
        +datetime created_at
        +validate()
        +update()
    }
    
    class TestResult {
        +int id
        +int student_id
        +int test_id
        +decimal marks_obtained
        +decimal percentage
        +string grade
        +int rank
        +datetime result_date
        +calculatePercentage()
        +assignGrade()
    }
    
    %% Document Management
    class Document {
        +int id
        +int student_id
        +string document_type
        +string file_name
        +string file_path
        +int uploaded_by
        +datetime uploaded_at
        +upload()
        +download()
        +delete()
    }
    
    %% Relationships
    User "1" --> "1" Role : has
    User "1" <|-- "1" Counsellor : extends
    User "1" <|-- "1" Principal : extends
    User "1" <|-- "1" Accountant : extends
    
    Student "1" --> "1" Course : enrolled in
    Student "1" --> "1" School : studies at
    Student "1" --> "1" Board : follows
    Student "1" --> "1" Medium : studies in
    Student "1" --> "0..1" Group : belongs to
    Student "many" --> "0..1" Counsellor : assigned to
    Student "1" --> "0..1" EnrolledStudent : has
    
    EnrolledStudent "1" --> "1" Student : refers to
    EnrolledStudent "1" --> "1" Course : enrolled in
    EnrolledStudent "1" --> "1" School : at
    
    FeeConfiguration "1" --> "1" Course : for
    FeeConfiguration "1" --> "1" School : at
    FeeConfiguration "1" --> "1" Medium : in
    FeeConfiguration "1" --> "0..1" Group : for
    
    Student "1" --> "1" StudentFeeAllocation : has
    StudentFeeAllocation "1" --> "1" FeeConfiguration : based on
    
    Student "1" --> "many" Payment : makes
    Payment "1" --> "1" User : processed by
    
    Student "1" --> "many" InstallmentRequest : creates
    InstallmentRequest "1" --> "many" Installment : contains
    InstallmentRequest "1" --> "0..1" User : approved by
    
    Student "1" --> "many" CounsellingSession : participates in
    Counsellor "1" --> "many" CounsellingSession : conducts
    
    Student "1" --> "many" Appointment : books
    Counsellor "1" --> "many" Appointment : has
    
    ScholarshipType "1" --> "many" ScholarshipRule : defines
    ScholarshipRule "1" --> "1" Course : applies to
    
    Student "1" --> "many" TestResult : has
    Test "1" --> "many" TestResult : produces
    Test "1" --> "1" AnswerKey : has
    Test "1" --> "1" Course : for
    
    Student "1" --> "many" Document : uploads
    Document "1" --> "1" User : uploaded by
    
    %% Notes
    note for User "Base class for all system users\nHandles authentication & authorization"
    note for Student "Main entity representing a student\nTracks registration to enrollment"
    note for Payment "Records all financial transactions\nSupports online and offline modes"
    note for FeeConfiguration "Defines fee structure based on\nCourse, School, Medium, and Group"
