%% Student Registration Activity Diagram
%% Shows the complete flow of student registration process

flowchart TD
    Start([Student Starts Registration]) --> CheckLogin{Already<br/>Registered?}
    CheckLogin -->|Yes| Login[Login to Portal]
    CheckLogin -->|No| FillForm[Fill Registration Form]
    
    FillForm --> EnterPersonal[Enter Personal Details]
    EnterPersonal --> SelectCourse[Select Course & Medium]
    SelectCourse --> SelectSchool[Choose School Preference]
    SelectSchool --> UploadDocs[Upload Documents]
    
    UploadDocs --> ValidateForm{Form<br/>Valid?}
    ValidateForm -->|No| ShowError[Show Validation Errors]
    ShowError --> FillForm
    ValidateForm -->|Yes| SubmitForm[Submit Registration]
    
    SubmitForm --> SaveData[(Save to Database)]
    SaveData --> GenerateID[Generate Student ID]
    GenerateID --> SendEmail[Send Confirmation Email]
    SendEmail --> AssignCounsellor{Auto-Assign<br/>Counsellor?}
    
    AssignCounsellor -->|Yes| AssignToCounsellor[Assign to Available Counsellor]
    AssignCounsellor -->|No| WaitForAssignment[Wait for Manual Assignment]
    
    AssignToCounsellor --> NotifyCounsellor[Notify Counsellor]
    NotifyCounsellor --> DisplaySuccess[Display Success Message]
    WaitForAssignment --> DisplaySuccess
    
    Login --> ViewProfile[View Profile Dashboard]
    DisplaySuccess --> End([Registration Complete])
    ViewProfile --> End
    
    style Start fill:#C8E6C9
    style End fill:#FFCDD2
    style SaveData fill:#E1BEE7
    style CheckLogin fill:#FFF9C4
    style ValidateForm fill:#FFF9C4
    style AssignCounsellor fill:#FFF9C4
