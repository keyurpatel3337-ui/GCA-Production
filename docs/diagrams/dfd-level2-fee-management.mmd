%% Data Flow Diagram - Level 2
%% Process 4.0: Fee Management (Detailed)

graph TB
    %% External Entities
    Accountant([Accountant])
    Principal([Principal])
    Student([Student])
    
    %% Sub-Processes
    P41[("4.1<br/>Configure<br/>Fee<br/>Structure")]
    P42[("4.2<br/>Process<br/>Installment<br/>Request")]
    P43[("4.3<br/>Approve<br/>Installment<br/>(Accountant)")]
    P44[("4.4<br/>Approve<br/>Installment<br/>(Principal)")]
    P45[("4.5<br/>Create<br/>Installment<br/>Schedule")]
    P46[("4.6<br/>Track<br/>Due<br/>Payments")]
    P47[("4.7<br/>Send<br/>Payment<br/>Reminders")]
    P48[("4.8<br/>Process<br/>Fee<br/>Adjustment")]
    
    %% Data Stores
    D1[(D1: Students)]
    D2[(D2: Fee Config)]
    D3[(D3: Fee Allocation)]
    D4[(D4: Installment Requests)]
    D5[(D5: Installments)]
    D6[(D6: Payments)]
    D7[(D7: Courses)]
    
    %% Process 4.1 - Configure Fee Structure
    Accountant -->|Fee Configuration<br/>Course, School<br/>Medium, Group| P41
    P41 <-->|Course Info| D7
    P41 -->|Fee Components:<br/>- School Fee<br/>- Trust Fee<br/>- Tuition Part 1<br/>- Tuition Part 2<br/>- Hostel Fee<br/>- Total Amount<br/>- Installment Options| P41
    P41 -->|Fee Structure| D2
    P41 -->|Configuration Saved| Accountant
    
    %% Process 4.2 - Installment Request
    Student -->|Request Installments<br/>Fee Component<br/>Desired Installments<br/>Reason| P42
    P42 <-->|Student Details| D1
    P42 <-->|Fee Info| D3
    P42 -->|Eligibility Check:<br/>- Pending Amount<br/>- Previous Requests<br/>- Payment History| P42
    P42 -->|Not Eligible| Student
    P42 -->|Request Created| D4
    P42 -->|Request Pending| P43
    P42 -->|Request Status| Student
    
    %% Process 4.3 - Accountant Approval
    P43 <-->|Installment Request| D4
    P43 <-->|Student Financial History| D6
    P43 <-->|Fee Details| D3
    P43 -->|Verify:<br/>- Payment Capacity<br/>- Previous Defaults<br/>- Request Validity| P43
    P43 -->|Rejected<br/>Rejection Reason| Student
    P43 <-->|Update Status<br/>Accountant Approved| D4
    P43 -->|Approved| P44
    
    %% Process 4.4 - Principal Approval
    Principal <-->|View Request<br/>Accountant Remarks| D4
    Principal -->|Approval/Rejection| P44
    P44 <-->|Request Details| D4
    P44 <-->|Student Info| D1
    P44 -->|Rejected<br/>Rejection Reason| Student
    P44 <-->|Update Status<br/>Principal Approved| D4
    P44 -->|Final Approval| P45
    
    %% Process 4.5 - Create Installment Schedule
    P45 <-->|Approved Request| D4
    P45 <-->|Fee Allocation| D3
    P45 -->|Calculate:<br/>Total Amount ÷ Installments<br/>Generate Due Dates<br/>30-day intervals| P45
    P45 -->|Installment Schedule| D5
    P45 -->|Schedule Details:<br/>- Installment Numbers<br/>- Amounts<br/>- Due Dates| Student
    P45 -->|Schedule Created| Accountant
    
    %% Process 4.6 - Track Due Payments
    P46 <-->|Installment Schedule| D5
    P46 <-->|Payment Records| D6
    P46 -->|Check:<br/>- Current Date vs Due Date<br/>- Payment Status<br/>- Overdue Days| P46
    P46 -->|Upcoming/Overdue List| P47
    
    %% Process 4.7 - Send Reminders
    P47 <-->|Due Installments| D5
    P47 <-->|Student Contact| D1
    P47 -->|7 Days Before:<br/>Reminder Email<br/>Payment Details| Student
    P47 -->|On Due Date:<br/>Payment Due Notice| Student
    P47 -->|After Due Date:<br/>Overdue Notice<br/>Penalty Info| Student
    P47 -->|Daily Summary:<br/>Overdue Report| Accountant
    P47 -->|Weekly Summary| Principal
    
    %% Process 4.8 - Fee Adjustment
    Accountant -->|Adjustment Request<br/>Student ID<br/>Adjustment Type<br/>Amount, Reason| P48
    Principal -->|Adjustment Approval| P48
    P48 <-->|Current Fee Allocation| D3
    P48 -->|Adjustment Types:<br/>- Scholarship Addition<br/>- Fee Waiver<br/>- Penalty Reversal<br/>- Manual Correction| P48
    P48 <-->|Update Allocation<br/>Adjusted Amounts| D3
    P48 -->|Adjustment Notification| Student
    P48 -->|Adjustment Record| Accountant
    
    %% Styling
    classDef entityStyle fill:#E3F2FD,stroke:#1976D2,stroke-width:3px
    classDef processStyle fill:#C8E6C9,stroke:#388E3C,stroke-width:3px
    classDef datastoreStyle fill:#FFE0B2,stroke:#E65100,stroke-width:3px
    
    class Student,Accountant,Principal entityStyle
    class P41,P42,P43,P44,P45,P46,P47,P48 processStyle
    class D1,D2,D3,D4,D5,D6,D7 datastoreStyle
