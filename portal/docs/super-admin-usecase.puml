@startuml Super Admin Use Case Diagram

left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle

' Styling
skinparam usecase {
    BackgroundColor<<core>> #E3F2FD
    BackgroundColor<<master>> #E8F5E9
    BackgroundColor<<division>> #FFF3E0
    BackgroundColor<<comm>> #F3E5F5
    BackgroundColor<<fee>> #FFEBEE
    BackgroundColor<<academic>> #E0F7FA
    BackgroundColor<<account>> #FBE9E7
}

' Actor
actor "Super Admin" as SA #2563eb

' System boundary
rectangle "GCA Portal" {
    
    ' Core Features
    package "Dashboard" {
        usecase "View Dashboard Statistics" as UC1 <<core>>
        usecase "Monitor Registrations" as UC2 <<core>>
        usecase "Track Enrollments" as UC3 <<core>>
    }
    
    ' Master Data Management
    package "Master Data Management" {
        usecase "Manage Academic Years" as UC10 <<master>>
        usecase "Manage Boards" as UC11 <<master>>
        usecase "Manage Courses" as UC12 <<master>>
        usecase "Manage Schools" as UC13 <<master>>
        usecase "Manage Medium" as UC14 <<master>>
        usecase "Manage Groups" as UC15 <<master>>
        usecase "Manage Terms" as UC16 <<master>>
    }
    
    ' Division Management
    package "Division Management" {
        usecase "Manage Divisions" as UC20 <<division>>
        usecase "Map Course to Division" as UC21 <<division>>
        usecase "Assign Division to Students" as UC22 <<division>>
        usecase "Approve Division Requests" as UC23 <<division>>
        usecase "Shuffle Divisions" as UC24 <<division>>
    }
    
    ' Communication
    package "Communication" {
        usecase "Manage WhatsApp Templates" as UC30 <<comm>>
        usecase "View WhatsApp Logs" as UC31 <<comm>>
        usecase "Manage Email Templates" as UC32 <<comm>>
        usecase "View Email Logs" as UC33 <<comm>>
    }
    
    ' Fee Management
    package "Fee Management" {
        usecase "Configure Fees" as UC40 <<fee>>
        usecase "Configure Hostel Fees" as UC41 <<fee>>
        usecase "Assign Fees to Students" as UC42 <<fee>>
        usecase "Configure Fee Splits" as UC43 <<fee>>
        usecase "Process Installment Requests" as UC44 <<fee>>
        usecase "Configure Receipts" as UC45 <<fee>>
        usecase "Manage Payment Gateways" as UC46 <<fee>>
    }
    
    ' Scholarship
    package "Scholarship Management" {
        usecase "Manage Scholarship Types" as UC50 <<academic>>
        usecase "Configure Scholarship Rules" as UC51 <<academic>>
    }
    
    ' Test Marks
    package "Test Marks Management" {
        usecase "View All Test Marks" as UC60 <<academic>>
        usecase "Add Single Test Mark" as UC61 <<academic>>
        usecase "Bulk Upload Test Marks" as UC62 <<academic>>
    }
    
    ' Account Management
    package "Account & Settings" {
        usecase "Manage Profile" as UC70 <<account>>
        usecase "Configure System Settings" as UC71 <<account>>
        usecase "Logout" as UC72 <<account>>
    }
}

' Relationships - Dashboard
SA --> UC1
SA --> UC2
SA --> UC3

' Relationships - Master Data
SA --> UC10
SA --> UC11
SA --> UC12
SA --> UC13
SA --> UC14
SA --> UC15
SA --> UC16

' Relationships - Division
SA --> UC20
SA --> UC21
SA --> UC22
SA --> UC23
SA --> UC24

' Relationships - Communication
SA --> UC30
SA --> UC31
SA --> UC32
SA --> UC33

' Relationships - Fee
SA --> UC40
SA --> UC41
SA --> UC42
SA --> UC43
SA --> UC44
SA --> UC45
SA --> UC46

' Relationships - Scholarship
SA --> UC50
SA --> UC51

' Relationships - Test Marks
SA --> UC60
SA --> UC61
SA --> UC62

' Relationships - Account
SA --> UC70
SA --> UC71
SA --> UC72

' Include relationships
UC42 ..> UC40 : <<include>>
UC43 ..> UC40 : <<include>>
UC24 ..> UC20 : <<include>>
UC21 ..> UC20 : <<include>>
UC22 ..> UC20 : <<include>>

' Legend
legend right
    |= Color |= Category |
    | <#E3F2FD> | Core Dashboard |
    | <#E8F5E9> | Master Data |
    | <#FFF3E0> | Division Mgmt |
    | <#F3E5F5> | Communication |
    | <#FFEBEE> | Fee Management |
    | <#E0F7FA> | Academic |
    | <#FBE9E7> | Account |
endlegend

@enduml
