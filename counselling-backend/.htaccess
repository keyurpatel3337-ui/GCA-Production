# Backend API .htaccess
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # If the request is for an existing file or directory, serve it directly
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Route API requests through index.php
    # Supports: /api/module/action -> index.php?route=module/action
    RewriteRule ^api/(.*)$ index.php?route=$1 [QSA,L]
    
    # Alternative: Route all non-file requests through index.php
    # RewriteRule ^(.*)$ index.php?route=$1 [QSA,L]
</IfModule>

# Enable CORS - Handled in PHP config.php for better control
<IfModule mod_headers.c>
    # Allow credentials for CORS
    Header always set Access-Control-Allow-Credentials "true"
</IfModule>

# Enable compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE application/json text/plain text/xml application/xml
</IfModule>
